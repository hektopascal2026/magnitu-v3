# --- Gemini (same convention as transcribe-v3 / tourdesuisse) ---
# Copy to .env and fill in. Do not commit .env.
GEMINI_API_KEY=AIza...
GEMINI_MODEL=models/gemini-2.5-flash
# Optional: use a different (faster/cheaper) model for batch or chunk work.
# Leave empty to use GEMINI_MODEL for everything.
GEMINI_CHUNK_MODEL=
# Optional tuning (see magnitu/gemini_config.py)
# GEMINI_TEMPERATURE=0
# GEMINI_MAX_OUTPUT_TOKENS=8192
# GEMINI_TIMEOUT_S=120
# GEMINI_MAX_RETRIES=4
# GEMINI_JSON_RETRIES=3
# GEMINI_RETRY_BACKOFF_S=8
# Send responseSchema with JSON MIME (1) or MIME-only JSON (0; client may fall back on 400).
# GEMINI_STRICT_SCHEMA=0

# Seismo + app settings live in magnitu_config.json (see magnitu_config.example.json).
