# ── Secrets (never commit) ──
.env

# ── Local app data & config (default is outside the repo; legacy paths here) ──
magnitu.db
magnitu.db-shm
magnitu.db-wal
magnitu_config.json

# ── Python bytecode ──
*.pyc
__pycache__/

