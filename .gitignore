# ── Secrets (never commit) ──
.env

# ── Local app data & config (per machine; paths from config.py / env) ──
magnitu.db
magnitu.db-shm
magnitu.db-wal
magnitu_config.json

# ── Python bytecode ──
*.pyc
__pycache__/

